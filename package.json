{
  "main": "src/main.ts",
  "scripts": {
    "start": "tsc",
    "start:dev": "nodemon --watch 'apps/aoc-2019/src/**/*.ts' --ignore 'apps/aoc-2019/src/**/*.spec.ts' --exec 'ts-node' apps/aoc-2019/src/main.ts",
    "start:2020:millions-of-cups": "nodemon --watch 'src/**/*.ts' --ignore 'src/**/*.spec.ts' --exec 'ts-node' -r tsconfig-paths/register src/2020/day-23/play-millions-of-cups.ts",
    "format:fix": "pretty-quick --staged",
    "lint": "tslint --project ./tsconfig.json --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "tsnode": "ts-node"
  },
  "husky": {
    "hooks": {
      "pre-commit": "run-s format:fix lint test"
    }
  },
  "jest": {
    "globals": {
      "ts-jest": {
        "tsConfig": "tsconfig.test.json"
      }
    }
  },
  "engines": {
    "node": "^16.15.0"
  },
  "dependencies": {
    "cli-progress": "^3.8.2",
    "promise.any": "^2.0.1",
    "rxjs": "6.6.3",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@nrwl/eslint-plugin-nx": "15.2.4",
    "@nrwl/jest": "15.2.4",
    "@nrwl/linter": "15.2.4",
    "@nrwl/node": "15.2.4",
    "@types/cli-progress": "^3.8.0",
    "@types/jest": "28.1.1",
    "@types/node": "18.7.1",
    "@types/ramda": "^0.27.32",
    "@typescript-eslint/eslint-plugin": "^5.36.1",
    "@typescript-eslint/parser": "^5.36.1",
    "eslint": "~8.15.0",
    "eslint-config-prettier": "8.1.0",
    "husky": "^4.3.5",
    "jest": "28.1.1",
    "jest-environment-jsdom": "28.1.1",
    "jest-preset-angular": "^8.3.2",
    "nodemon": "^2.0.7",
    "npm-run-all": "^4.1.5",
    "nx": "15.2.4",
    "prettier": "^2.2.1",
    "pretty-quick": "^3.1.0",
    "ramda": "^0.27.1",
    "rxjs-tslint-rules": "^4.34.7",
    "ts-jest": "28.0.5",
    "ts-node": "10.9.1",
    "tsconfig-paths": "^3.9.0",
    "tslint": "^5.20.1",
    "tslint-config-prettier": "^1.18.0",
    "tslint-config-standard": "^9.0.0",
    "tslint-plugin-prettier": "^2.3.0",
    "typescript": "^4.3.0"
  }
}
